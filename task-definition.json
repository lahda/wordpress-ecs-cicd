{
  "family": "wordpress-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::423503571168:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::423503571168:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "wordpress",
      "image": "423503571168.dkr.ecr.us-east-1.amazonaws.com/wordpress",
      "portMappings": [
        {
          "containerPort": 80,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "WORDPRESS_DB_HOST",
          "value": "wordpress-db.catmw2awyd38.us-east-1.rds.amazonaws.com"
        },
        {
          "name": "WORDPRESS_DB_USER",
          "value": "admin"
        },
        {
          "name": "WORDPRESS_DB_NAME",
          "value": "wordpress"
        }
      ],
      "secrets": [
        {
          "name": "WORDPRESS_DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:423503571168:secret:wordpress/db/password-PJJ6Pt"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "wordpress-efs",
          "containerPath": "/var/www/html/wp-content",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/wordpress",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "wordpress"
        }
      }
    }
  ],
  "volumes": [
    {
      "name": "wordpress-efs",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0daaebf605585a590",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-0af4264ea4b85d1a5",
          "iam": "ENABLED"
        }
      }
    }
  ]
}
